generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int               @id @default(autoincrement())
  name          String
  email         String            @unique
  password      String
  role          String            @default("user") // admin or user
  avatar        String?
  role_id       Int?
  dept_id       Int?
  unit_id       Int?
  system_role   SystemRole?       @relation(fields: [role_id], references: [id])
  department    SystemDepartment? @relation(fields: [dept_id], references: [id])
  unit          SystemUnit?       @relation(fields: [unit_id], references: [id])
  files         File[]
  messages      Message[]
  notes         Note[]
  activities    Activity[]
  tasks         Task[]
  SharedNote    SharedNote[]
  SharedTask    SharedTask[]
  notifications Notification[]
  projects      Project[]
  ProjectShare  ProjectShare[]
}

model Notification {
  id          Int      @id @default(autoincrement())
  user_id     Int
  type        String   // MENTION, etc
  title       String
  content     String
  link        String?  // Ex: /chat?channel=1&message=123
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model SystemRole {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

model SystemDepartment {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

model SystemUnit {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

model Channel {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  messages    Message[]
}

model Message {
  id         Int      @id @default(autoincrement())
  channel_id Int
  user_id    Int
  content    String   @db.Text
  is_announcement Boolean @default(false)
  created_at DateTime @default(now())
  channel    Channel  @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([channel_id], map: "Message_channel_id_fkey")
  @@index([user_id], map: "Message_user_id_fkey")
}

model Note {
  id         Int          @id @default(autoincrement())
  user_id    Int
  title      String
  content    String?      @db.Text
  color      String       @default("#ffffff")
  is_pinned  Boolean      @default(false)
  created_at DateTime     @default(now())
  user       User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  shares     SharedNote[]

  @@index([user_id], map: "Note_user_id_fkey")
}

model SharedNote {
  id         Int    @id @default(autoincrement())
  note_id    Int
  user_id    Int
  permission String @default("VIEW") // VIEW or EDIT
  note       Note   @relation(fields: [note_id], references: [id], onDelete: Cascade)
  user       User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([note_id])
  @@index([user_id])
}

model Task {
  id          Int          @id @default(autoincrement())
  user_id     Int
  project_id  Int?
  title       String
  description String?      @db.Text
  due_date    DateTime?
  status      String       @default("TODO") // TODO, IN_PROGRESS, REVIEW, DONE
  priority    String       @default("MEDIUM") // LOW, MEDIUM, HIGH
  order       Int          @default(0)
  is_shared   Boolean      @default(false)
  created_at  DateTime     @default(now())
  user        User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  project     Project?     @relation(fields: [project_id], references: [id], onDelete: SetNull)
  shares      SharedTask[]

  @@index([user_id], map: "tasks_user_id_fkey")
  @@index([project_id])
  @@map("tasks")
}

model Project {
  id          Int            @id @default(autoincrement())
  name        String
  description String?        @db.Text
  color       String         @default("#3b82f6")
  user_id     Int
  user        User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tasks       Task[]
  shares      ProjectShare[]
  created_at  DateTime       @default(now())

  @@index([user_id])
}

model ProjectShare {
  id         Int     @id @default(autoincrement())
  project_id Int
  user_id    Int
  permission String  @default("VIEW") // VIEW or EDIT
  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([user_id])
}

model SharedTask {
  id         Int    @id @default(autoincrement())
  task_id    Int
  user_id    Int
  permission String @default("VIEW") // VIEW or EDIT
  task       Task   @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user       User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([task_id])
  @@index([user_id])
}

model File {
  id         Int      @id @default(autoincrement())
  user_id    Int
  name       String
  size       Int
  type       String
  content    String   @db.LongText
  folder     String   @default("General")
  location   String   @default("PERSONAL")
  is_shared  Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "File_user_id_fkey")
}

model Activity {
  id          Int      @id @default(autoincrement())
  user_id     Int
  type        String
  description String
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "activities_user_id_fkey")
  @@map("activities")
}
